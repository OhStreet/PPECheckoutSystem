<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PPE Checkout System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    PPE Checkout System
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Employees" asp-action="Index">Employees</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Equipment" asp-action="Index">Equipment</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Equipment" asp-action="Available">Available Inventory</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Checkouts" asp-action="Create">Checkout</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Checkouts" asp-action="Lookup">Lookup</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Registration" asp-action="Register">Register Employee</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container app-main">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="app-footer">
        <div class="container">
            <span>&copy; @DateTime.Now.Year - PPE Checkout System</span>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>